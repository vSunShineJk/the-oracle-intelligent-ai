# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# ── Secrets ──────────────────────────────────────────────────────────────────
# .env holds ALL API keys and tokens (Azure, Telegram, confirmation code).
# NEVER commit this file. Copy .env.example → .env locally and fill it in.
.env
*.env
*.env.*

# Google OAuth credentials and tokens — downloaded from Google Cloud Console
# and generated by tools/google/auth.py. Committing these would give anyone
# full access to the Gmail and Calendar accounts.
/tools/google/credentials/

# ── Local databases ──────────────────────────────────────────────────────────
# SQLite .db files contain actual personal gmail data synced from Gmail.
# They are large, binary, and contain private information — never commit them.
*.db

# ── IDE / editor files ───────────────────────────────────────────────────────
# PyCharm stores local workspace config in .idea/ (run configs, local paths, etc.)
# These are machine-specific and should not be shared via git.
.idea/

# ── Claude Code local settings ───────────────────────────────────────────────
# .claude/ holds Claude Code session state and local permission settings.
# It is not part of the project source and should stay off GitHub.
.claude/

# ── Temporary / scratch files ────────────────────────────────────────────────
tmp.txt


/documentation
/memories/user.md
memories/facts.md
memories/sessions.md
/part2
/voice/usage_log.json